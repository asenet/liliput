      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=\"demo\"}",
          "queryType": "stats",
          "datasource": { "type": "liliput-datasource", "uid": "liliput" }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/cost_saved_aws_cloudwatch/" },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 35,
      "title": "Datadog saved/mo",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 13 },
      "datasource": { "type": "liliput-datasource", "uid": "liliput" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "dark-purple" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=\"demo\"}",
          "queryType": "stats",
          "datasource": { "type": "liliput-datasource", "uid": "liliput" }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/cost_saved_datadog/" },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 36,
      "title": "Splunk Cloud saved/mo",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 13 },
      "datasource": { "type": "liliput-datasource", "uid": "liliput" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "semi-dark-green" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=\"demo\"}",
          "queryType": "stats",
          "datasource": { "type": "liliput-datasource", "uid": "liliput" }
        }
      ],
