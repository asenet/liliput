        "justifyMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 20,
      "title": "Template Registry",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "liliput-datasource", "uid": "liliput" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ID" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "Params" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "templates",
          "datasource": { "type": "liliput-datasource", "uid": "liliput" }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": true, "reducer": ["count"], "countRows": true }
      }
    },
    {
      "id": 1,
      "title": "Raw logs (compact payloads in Loki)",
      "type": "logs",
      "pluginVersion": "10.4.0",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 25 },
      "datasource": { "type": "loki", "uid": "loki-raw" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=\"demo\"}",
          "datasource": { "type": "loki", "uid": "loki-raw" }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 2,
      "title": "Rehydrated logs (decoded by Liliput)",
      "type": "logs",
      "pluginVersion": "10.4.0",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 35 },
      "datasource": { "type": "liliput-datasource", "uid": "liliput" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=\"demo\"}",
          "search": "$search",
          "severity": "$severity",
          "datasource": { "type": "liliput-datasource", "uid": "liliput" }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
